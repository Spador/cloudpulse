# CloudPulse — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Required if not using an IAM role (EC2/Lambda instance profile)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# For local DynamoDB (Docker): uncomment and set this
# AWS_ENDPOINT_URL=http://localhost:8000

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=cloudpulse-costs

# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production-use-a-long-random-string
FLASK_APP=app.py

# ─── Application ──────────────────────────────────────────────────────────────
# Set to "true" to force mock data regardless of AWS credentials
MOCK_MODE=false

# Number of past days to fetch when snapshotting costs
COST_SNAPSHOT_DAYS=90

# Fractional spike threshold for anomaly detection (0.20 = 20%)
ANOMALY_THRESHOLD=0.20

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Terraform (used by execution/validate_terraform.py) ──────────────────────
TF_STATE_BUCKET=cloudpulse-tf-state-YOUR_ACCOUNT_ID
TF_STATE_KEY=cloudpulse/terraform.tfstate
TF_STATE_REGION=us-east-1
